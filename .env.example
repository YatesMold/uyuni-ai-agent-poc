# Copy this file to .env and fill in your values.
# Never commit .env to git.

PROMETHEUS_URL=http://localhost:9090
MINION_ID=myminion.mgr.suse.de

# Get a free Gemini API key at https://aistudio.google.com/apikey
LLM_API_KEY=your_gemini_api_key_here

# AlertManager integration (optional — disabled by default)
ALERTMANAGER_URL=http://localhost:9093
ALERTMANAGER_ENABLED=false

# Per-metric threshold overrides (optional — defaults shown below)
THRESHOLD_CPU=90.0
THRESHOLD_MEMORY=85.0
THRESHOLD_DISK=90.0
THRESHOLD_LOAD=2.0
THRESHOLD_APACHE_WORKERS=150.0
THRESHOLD_POSTGRES_CONNECTIONS=100.0

# Deprecated: THRESHOLD was used by the old single-metric loop in main.py.
# It has no effect now; use THRESHOLD_LOAD above instead.
# THRESHOLD=2.0
